# ==========================================
# BQ2 FINAL: Per-class F1 heatmap
# ==========================================
from sklearn.metrics import precision_recall_fscore_support

metrics_data = {}
for name, preds in [('Naive Bayes', y_pred_nb),
                     ('LR Default', y_pred_lr),
                     ('LR Tuned',   y_pred_lr_tuned)]:
    p, r, f, _ = precision_recall_fscore_support(y_test, preds, labels=[0,1,2,3])
    metrics_data[name] = f

metrics_df = pd.DataFrame(metrics_data, index=label_names)

plt.figure(figsize=(9, 4))
sns.heatmap(metrics_df, annot=True, fmt='.3f', cmap='YlOrRd',
            linewidths=0.5, vmin=0, vmax=1)
plt.title('BQ2: F1-Score per Class per Model (Hardest Classes = Lowest Values)',
          fontsize=13, fontweight='bold')
plt.ylabel('Sentiment Class', fontsize=11)
plt.xlabel('Model', fontsize=11)
plt.tight_layout()
